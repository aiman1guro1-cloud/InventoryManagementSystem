@model InventoryManagementSystem.Core.Entities.Cart

@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container">
    <h1 class="mt-4">Shopping Cart</h1>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model?.CartItems == null || !Model.CartItems.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x" style="font-size: 4rem; color: #ccc;"></i>
            <h3 class="mt-3 text-muted">Your cart is empty</h3>
            <a asp-controller="Products" asp-action="Index" class="btn btn-primary mt-3">
                Continue Shopping
            </a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Cart Items (@Model.TotalItems items)</h5>
                    </div>
                    <div class="card-body">
                        @foreach (var item in Model.CartItems)
                        {
                            <div class="row mb-3 pb-3 border-bottom">
                                <div class="col-md-6">
                                    <h6>@item.ProductName</h6>
                                    <small class="text-muted">SKU: @item.ProductSKU</small>
                                </div>
                                <div class="col-md-2">
                                    <span class="badge bg-info">@item.UnitPrice.ToString("C")</span>
                                </div>
                                <div class="col-md-2">
                                    <form asp-action="UpdateQuantity" method="post" class="d-flex align-items-center">
                                        <input type="hidden" name="cartItemId" value="@item.Id" />
                                        <input type="number" name="quantity" value="@item.Quantity"
                                               min="1" max="@(item.Product?.QuantityInStock ?? 99)"
                                               class="form-control form-control-sm" style="width: 70px;" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary ms-2">
                                            <i class="bi bi-arrow-repeat"></i>
                                        </button>
                                    </form>
                                </div>
                                <div class="col-md-2 text-end">
                                    <strong>@item.TotalPrice.ToString("C")</strong>
                                    <form asp-action="RemoveFromCart" method="post" class="d-inline ms-2">
                                        <input type="hidden" name="cartItemId" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">Order Summary</h5>
                    </div>
                    <div class="card-body">
                        <table class="table table-sm">
                            <tr>
                                <td>Subtotal:</td>
                                <td class="text-end"><strong>@Model.Subtotal.ToString("C")</strong></td>
                            </tr>
                            <tr>
                                <td>Tax (10%):</td>
                                <td class="text-end"><strong>@Model.TaxAmount.ToString("C")</strong></td>
                            </tr>
                            <tr class="border-top">
                                <td><h6>Total:</h6></td>
                                <td class="text-end"><h5 class="text-success">@Model.Total.ToString("C")</h5></td>
                            </tr>
                        </table>

                        <div class="d-grid gap-2">
                            <a asp-controller="Products" asp-action="Index" class="btn btn-outline-primary">
                                <i class="bi bi-plus-circle"></i> Add More Items
                            </a>
                            <form asp-action="ClearCart" method="post">
                                <button type="submit" class="btn btn-outline-warning w-100">
                                    <i class="bi bi-cart-x"></i> Clear Cart
                                </button>
                            </form>
                            <a asp-controller="Checkout" asp-action="Index" class="btn btn-success btn-lg w-100">
                                <i class="bi bi-credit-card"></i> Proceed to Checkout
                            </a>
                            <small class="text-muted text-center">(Checkout coming soon!)</small>
                        </div>
                    </div>
                </div>

                <div class="card mt-3">
                    <div class="card-body">
                        <h6><i class="bi bi-info-circle"></i> Quick Calculator</h6>
                        <div class="input-group mb-2">
                            <span class="input-group-text">Items</span>
                            <input type="number" id="quickCalcQty" class="form-control" value="1" min="1" />
                            <span class="input-group-text">×</span>
                            <input type="number" id="quickCalcPrice" class="form-control" placeholder="Price" />
                        </div>
                        <button class="btn btn-sm btn-primary w-100" onclick="calculateQuick()">
                            Calculate
                        </button>
                        <p class="mt-2 mb-0 text-center" id="quickCalcResult"></p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function calculateQuick() {
            const qty = document.getElementById('quickCalcQty').value || 1;
            const price = document.getElementById('quickCalcPrice').value || 0;
            const total = qty * price;
            document.getElementById('quickCalcResult').innerHTML =
                `<strong>Total: ${new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(total)}</strong>`;
        }
    </script>
}