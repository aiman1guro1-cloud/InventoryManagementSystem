@model InventoryManagementSystem.Core.Entities.Supplier

@{
    ViewData["Title"] = "Delete Supplier";
}

<div class="container">
    <h1 class="mt-4 text-danger">Delete Supplier</h1>

    @if (ViewBag.ProductCount > 0)
    {
        <div class="alert alert-danger">
            <h5>Cannot Delete Supplier</h5>
            <p>
                This supplier provides <strong>@ViewBag.ProductCount products</strong>.
                Please reassign these products to another supplier before deleting.
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            <h5>Are you sure you want to delete this supplier?</h5>
            <p class="mb-0">This action cannot be undone.</p>
        </div>
    }

    <div class="card">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0">Supplier Details</h5>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Name)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Email)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Email)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Phone)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Phone)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Address)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Address)</dd>

                <dt class="col-sm-3">Products Supplied</dt>
                <dd class="col-sm-9">
                    <span class="badge @(ViewBag.ProductCount > 0 ? "bg-danger" : "bg-success")">
                        @ViewBag.ProductCount
                    </span>
                </dd>
            </dl>
        </div>
        <div class="card-footer">
            @if (ViewBag.ProductCount == 0)
            {
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </form>
            }
            else
            {
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            }
        </div>
    </div>
</div>