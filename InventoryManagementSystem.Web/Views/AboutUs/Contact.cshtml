@{
    ViewData["Title"] = "Contact Us";
}

<!-- Contact Hero -->
<section class="bg-primary text-white py-5">
    <div class="container text-center">
        <h1 class="display-4 fw-bold">Contact Us</h1>
        <p class="lead">Get in touch with the development team</p>
    </div>
</section>

<div class="container my-5">
    <div class="row g-4">
        <!-- Contact Information -->
        <div class="col-lg-5">
            <h2 class="fw-bold mb-4">Let's Connect</h2>
            <p class="lead mb-4">Have questions about the Inventory Management System? We're here to help!</p>

            <!-- Contact Cards -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary bg-gradient text-white rounded-3 p-3 me-3">
                            <i class="bi bi-envelope-fill fs-4"></i>
                        </div>
                        <div>
                            <h6 class="mb-1">Email Us</h6>
                            <a href="mailto:support@inventory.com" class="text-decoration-none">support@inventory.com</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary bg-gradient text-white rounded-3 p-3 me-3">
                            <i class="bi bi-telephone-fill fs-4"></i>
                        </div>
                        <div>
                            <h6 class="mb-1">Call Us</h6>
                            <a href="tel:+639123456789" class="text-decoration-none">+63 912 345 6789</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary bg-gradient text-white rounded-3 p-3 me-3">
                            <i class="bi bi-facebook fs-4"></i>
                        </div>
                        <div>
                            <h6 class="mb-1">Facebook</h6>
                            <a href="#" class="text-decoration-none">facebook.com/inventorysystem</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary bg-gradient text-white rounded-3 p-3 me-3">
                            <i class="bi bi-linkedin fs-4"></i>
                        </div>
                        <div>
                            <h6 class="mb-1">LinkedIn</h6>
                            <a href="#" class="text-decoration-none">/company/inventory-system</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary bg-gradient text-white rounded-3 p-3 me-3">
                            <i class="bi bi-geo-alt-fill fs-4"></i>
                        </div>
                        <div>
                            <h6 class="mb-1">Office Address</h6>
                            <p class="mb-0">123 Tech Street, Business District<br />Manila, Philippines 1000</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Contact Form -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-chat-dots"></i> Send Us a Message</h5>
                </div>
                <div class="card-body p-4">
                    <form>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Your Name</label>
                                <input type="text" class="form-control" placeholder="John Doe" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Your Email</label>
                                <input type="email" class="form-control" placeholder="john@example.com" required>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Subject</label>
                                <input type="text" class="form-control" placeholder="How can we help?">
                            </div>
                            <div class="col-12">
                                <label class="form-label">Message</label>
                                <textarea class="form-control" rows="5" placeholder="Your message here..."></textarea>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary btn-lg px-5">
                                    <i class="bi bi-send"></i> Send Message
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Map (Optional) -->
    <div class="card border-0 shadow-lg mt-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-map"></i> Find Us</h5>
        </div>
        <div class="card-body p-0">
            <div class="bg-light text-center p-5">
                <i class="bi bi-map-fill text-primary" style="font-size: 3rem;"></i>
                <p class="mt-2">Interactive map would be integrated here</p>
                <small class="text-muted">123 Tech Street, Manila, Philippines</small>
            </div>
        </div>
    </div>
</div>